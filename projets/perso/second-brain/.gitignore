data/raw/*
data/processed/*
data/db/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/db/.gitkeep

# Memory (private conversation history)
memory/*
!memory/.gitkeep

# Logs
logs/*
!logs/.gitkeep

