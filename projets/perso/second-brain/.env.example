# ============================================
# Second Brain — Configuration (example)
# ============================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:latest

# LLM Provider (décommenter pour utiliser une API cloud au lieu d'Ollama)
# Valeurs : ollama, openai, deepseek, anthropic, groq, openrouter, together
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat

# Telegram Settings
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated list of allowed usernames or user IDs
# LEAVE EMPTY to disable Telegram access entirely
TELEGRAM_ALLOWED_USERS=

# Embedding model (from sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
TOP_K=5

# API Security
# Set a strong random token to protect the API when exposed to the network.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty for localhost-only access.
API_AUTH_TOKEN=

# API Binding
# Use 127.0.0.1 for local-only, 0.0.0.0 to expose on the network (requires API_AUTH_TOKEN)
API_HOST=127.0.0.1
API_PORT=8000

# ── LLM Providers (optional) ─────────────────────────────────────────
# Leave empty to use local Ollama only.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-opus-20240229
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# OPENROUTER_API_KEY=sk-or-...
# TOGETHER_API_KEY=...

# ── Plugins ───────────────────────────────────────────────────────────
# Gmail (nécessite un mot de passe d'application Google)
# https://myaccount.google.com/apppasswords
# GMAIL_EMAIL=votre.email@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Notion
# https://www.notion.so/my-integrations
# NOTION_API_KEY=secret_...
# NOTION_DATABASE_ID=...

# Spotify
# SPOTIFY_CLIENT_ID=...
# SPOTIFY_CLIENT_SECRET=...
